# ─────────────────────────────────────────────
#  SofIA – Environment variables (Plantilla)
#  Copia este archivo a .env y rellena los valores
# ─────────────────────────────────────────────

# ── Base de Datos (Supabase / PostgreSQL) ─────
# Connection String URI (Recomendado)
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://usuario:password@host:5432/database
DB_SSL=true

# ── ElevenLabs (Audio) ────────────────────────
ELEVENLABS_API_KEY=tu_api_key_aqui
ELEVENLABS_AGENT_ID=tu_agent_id_aqui
ELEVENLABS_PHONE_NUMBER_ID=tu_phone_number_id_aqui
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/convai/twilio/outbound-call

# true  = Salta la llamada real (modo pruebas, no gasta saldo)
# false = Realiza la llamada telefónica real
ELEVENLABS_MOCK=false

# ── Chatbot Integration (Tu Compañera) ────────
# URL del webhook del chatbot (usualmente Ngrok)
CHATBOT_WEBHOOK_URL=https://tu-url-de-ngrok.ngrok-free.app/solicitar-chat

# ── Control de Llamadas ───────────────────────
# Máximo de llamadas simultáneas a Twilio
MAX_CONCURRENT_CALLS=4

# Intervalo del worker en segundos
QUEUE_WORKER_INTERVAL_SECONDS=10

# Tiempo (minutos) para marcar como NO_CONTESTA una llamada trabada
STALE_CALL_MINUTES=30

# ── Horarios de Llenado de Cola (Cron - Hora COL) ─
# Formato Cron: Minuto Hora Día Mes DiaSemana
CRON_FILL_MANANA=0 7 * * *
CRON_FILL_TARDE=0 14 * * *
CRON_FILL_NOCHE=0 19 * * *

# ── Servidor HTTP ─────────────────────────────
PORT=3000

# ── Zona Horaria ──────────────────────────────
TZ=America/Bogota
