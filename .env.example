# ─────────────────────────────────────────────
#  SofIA – Environment variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────
# Get from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DB_SSL=true

# ── ElevenLabs ────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_agent_id
ELEVENLABS_PHONE_NUMBER_ID=your_phone_number_id
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/convai/twilio/outbound-call

# Set to true to skip real calls during local testing (no phone will ring)
ELEVENLABS_MOCK=false

# ── Call control ──────────────────────────────
# Max simultaneous Twilio outbound calls
MAX_CONCURRENT_CALLS=4

# Worker tick interval in seconds
QUEUE_WORKER_INTERVAL_SECONDS=10

# EN_CURSO calls older than N minutes are auto-resolved as NO_CONTESTA
STALE_CALL_MINUTES=30

# How often (minutes) the worker backfills missing queue items
BACKFILL_INTERVAL_MINUTES=5

# ── Queue fill schedule (Colombia time, UTC-5) ─
# Cron jobs fill the queue at the start of each franja.
# On restart, the app also fills any franja that is missing items today.
CRON_FILL_MANANA=0 7 * * *
CRON_FILL_TARDE=0 14 * * *
CRON_FILL_NOCHE=0 19 * * *

# ── HTTP server ───────────────────────────────
PORT=3000

# ── Timezone ──────────────────────────────────
TZ=America/Bogota
