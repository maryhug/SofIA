{
  "name": "sofia",
  "version": "2.0.0",
  "description": "SofIA – Outbound call automation service",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "tunnel": "C:\\ngrok\\ngrok.exe http 3000",

    "// --- JURADO Y DEMO ---": "",
    "bot:invite-jurado": "node scripts/utils/invite-judge.js",

    "// --- OPERACIÓN DIARIA ---": "",
    "bot:trigger": "node scripts/utils/bulk-trigger-chatbot.js",
    "bot:check": "node scripts/utils/check-candidate.js",
    "bot:reset": "node scripts/utils/reset-candidate.js",

    "// --- UTILIDADES ---": "",
    "db:check": "node scripts/testing/test-db-connection.js",
    "db:events": "node scripts/utils/list-events.js",
    "test:ngrok": "node scripts/testing/test-ngrok.js",
    "test:direct": "node scripts/testing/test-chatbot-direct.js",

    "// --- MONITOREO Y LOGS ---": "",
    "logs:setup": "node scripts/db/setup-logs-db.js",
    "logs:view": "node scripts/utils/view-webhook-logs.js",
    "logs:clear": "node scripts/utils/clear-webhook-logs.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ngrok": "^5.0.0-beta.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0"
  },
  "engines": {
    "node": ">=18"
  },
  "private": true
}
